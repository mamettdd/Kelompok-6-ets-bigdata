# Salin file ini ke `.env` (di repo root) lalu isi nilainya.
# File `.env` sudah masuk .gitignore — token tidak akan ke-commit.

# ===== AQICN (sumber API real-time) =====
# Daftar token gratis: https://aqicn.org/data-platform/token/
# Kalau dikosongkan, producer otomatis pakai SIMULATOR (acak realistis).
AQICN_TOKEN=a2c7dc8e5197f429236c0a0445fc84d3d3a9bfae

# Set 1 untuk paksa simulator meski token ada (mode demo offline)
FORCE_SIMULATOR=0

# ===== Kafka =====
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_TOPIC_API=airquality-api
KAFKA_TOPIC_RSS=airquality-rss

# Polling interval (detik). Sesuai rubrik: API 15 menit (900), RSS 5 menit (300)
POLL_INTERVAL_SEC=900
POLL_INTERVAL_SEC_RSS=300

# ===== HDFS =====
HDFS_NAMENODE_URL=http://localhost:9870
HDFS_NAMENODE_RPC=hdfs://localhost:9000
HDFS_USER=root
HDFS_BASE_DIR=/data/airquality
# Nama container namenode (untuk strategi docker_exec write)
HDFS_NAMENODE_CONTAINER=namenode
# Cara write file ke HDFS:
#   docker_exec  → pakai `docker exec namenode hdfs dfs -put -` (default, anti-WSL2 issue)
#   webhdfs      → pakai library hdfs Python langsung (butuh datanode hostname reachable)
HDFS_WRITE_MODE=docker_exec

# ===== Consumer buffering =====
# Flush ke HDFS setiap 180 detik (3 menit), atau saat 200 record terkumpul
BUFFER_FLUSH_SEC=180
BUFFER_MAX_RECORDS=200

# Consumer group id (tiap topic punya group sendiri)
CONSUMER_GROUP_API=airquality-consumer-api
CONSUMER_GROUP_RSS=airquality-consumer-rss

# ===== RSS feeds =====
# Default (sudah hidup): Detik root + Tempo nasional + tag/polusi + Kompas environment.
# Producer akan filter keyword lingkungan (polusi/udara/lingkungan/aqi/asap/kabut/...).
# Kalau override, pisahkan dengan koma.
# RSS_FEEDS=https://news.detik.com/rss,https://rss.tempo.co/nasional
# RSS_KEYWORDS=polusi,udara,lingkungan,aqi,asap
# Top-N fallback bila tidak ada yang cocok keyword (untuk dashboard demo)
RSS_FALLBACK_TOPN=5
# User-Agent untuk request RSS (beberapa server menolak default Python)
# RSS_USER_AGENT=Mozilla/5.0 ...

# ===== Dashboard =====
PORT=5000
